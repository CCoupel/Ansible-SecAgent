# .env.example — Variables d'environnement requises pour AnsibleRelay
# Copier vers .env et remplir les valeurs avant docker compose up
#
# IMPORTANT : ne jamais committer .env dans git

# Clef secrète HMAC-SHA256 pour la signature des JWT agents
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-generate-a-strong-secret

# Token Bearer pour l'endpoint admin /api/admin/authorize
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=changeme-generate-a-strong-token
