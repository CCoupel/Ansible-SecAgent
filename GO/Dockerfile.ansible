# Dockerfile — Ansible Container with AnsibleRelay Plugins
#
# Multi-stage build :
# Stage 1 : Build relay-inventory binary (GO)
# Stage 2 : Ansible container (Python 3.11 + plugins)
#
# Container Ansible complet incluant :
# - ansible + ansible-core
# - Plugins relay (connection plugin Python)
# - relay-inventory (binaire GO pour inventaire dynamique)
# - Configuration ansible.cfg
# - Outils courants (curl, git, jq, etc.)
#
# Usage :
#   docker build -f Dockerfile.ansible -t relay-ansible .
#   docker run -it relay-ansible bash
#   ansible-playbook -i /usr/local/bin/relay-inventory my-playbook.yml

# ────────────────────────────────────────────────────────────────────────────
# Stage 1 : Build relay-inventory binary (GO)
# ────────────────────────────────────────────────────────────────────────────

FROM golang:1.25-alpine AS builder

WORKDIR /build

# Install build dependencies
RUN apk add --no-cache git make

# Copy GO source
COPY GO/go.mod GO/go.sum GO/go.work ./
COPY GO/cmd/inventory ./cmd/inventory

# Build relay-inventory binary
RUN go build -o /tmp/relay-inventory ./cmd/inventory

# ────────────────────────────────────────────────────────────────────────────
# Stage 2 : Ansible container
# ────────────────────────────────────────────────────────────────────────────

FROM python:3.11-slim

# Metadata
LABEL maintainer="AnsibleRelay Team"
LABEL description="Ansible container with AnsibleRelay connection + inventory plugins"
LABEL version="1.0"

# Set working directory
WORKDIR /ansible

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    jq \
    openssh-client \
    sshpass \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir \
    ansible-core>=2.14 \
    pyyaml \
    jinja2 \
    netaddr \
    requests \
    paramiko \
    cryptography

# Copy ansible.cfg
COPY PYTHON/ansible.cfg /ansible/

# Copy plugins directory structure
RUN mkdir -p /ansible/ansible_plugins/{connection_plugins,inventory_plugins}

# Copy connection plugin (relay.py)
COPY PYTHON/ansible_plugins/connection_plugins/relay.py /ansible/ansible_plugins/connection_plugins/
COPY PYTHON/ansible_plugins/connection_plugins/__init__.py /ansible/ansible_plugins/connection_plugins/

# Copy relay-inventory binary from builder stage
COPY --from=builder /tmp/relay-inventory /usr/local/bin/relay-inventory
RUN chmod +x /usr/local/bin/relay-inventory

# Create inventory directory
RUN mkdir -p /ansible/inventory /ansible/playbooks /ansible/roles

# Set ANSIBLE_PLUGINS_MODULES environment variable
ENV ANSIBLE_LIBRARY=/ansible/ansible_plugins/modules
ENV ANSIBLE_PLUGINS=/ansible/ansible_plugins

# Verify relay-inventory is available
RUN relay-inventory --help > /dev/null || echo "Warning: relay-inventory not found"

# Expose volume mount points
VOLUME ["/ansible/inventory", "/ansible/playbooks", "/ansible/roles", "/ansible/roles/defaults"]

# Default entry point
CMD ["bash"]

# Health check — verify ansible is installed
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD ansible --version
